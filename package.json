{
  "name": "cloudflare-playbook",
  "version": "0.1.0",
  "private": true,
  "description": "面向独立开发者和小型团队的 Cloudflare 单页实战手册。",
  "type": "module",
  "engines": {
    "node": ">=22.12.0"
  },
  "packageManager": "pnpm@10.28.1",
  "scripts": {
    "dev": "vitepress dev docs --host 127.0.0.1",
    "start": "vitepress dev docs --host 127.0.0.1",
    "build": "vitepress build docs",
    "preview": "vitepress preview docs --host 127.0.0.1",
    "deploy": "pnpm build && wrangler deploy"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/realchendahuang/cloudflare-playbook.git"
  },
  "devDependencies": {
    "vitepress": "^1.6.4",
    "wrangler": "^4.100.0"
  }
}
